# Palimpsest production env — copy to ops/docker/.env on the box, chmod 600.
# NEVER commit the real .env (repo .gitignore already excludes .env).

# --- database ----------------------------------------------------------------
POSTGRES_USER=palimpsest
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=palimpsest
# The app reads DATABASE_URL; host "postgres" is the compose service name.
DATABASE_URL=postgresql://palimpsest:change-me-to-a-long-random-string@postgres:5432/palimpsest

# --- queue (Celery over Redis) ----------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- data paths (inside the container) --------------------------------------
RAW_DATA_DIR=/app/data/raw
CENSORWATCH_ARCHIVE_DIR=/app/data/censorwatch

# --- LLM readings ------------------------------------------------------------
OPENROUTER_API_KEY=

# --- kill switch -------------------------------------------------------------
# If this file exists inside the container, collectors halt. Leave unset for
# normal operation; touch it (docker compose exec) to stop all fetching fast.
# PALIMPSEST_KILLFILE=/app/readings/state/STOP

# =============================================================================
# DECISION POINT — egress / vantage exit.  This is the choice that actually
# shapes what your measurements are worth, so decide it deliberately:
#
#   (a) DIRECT (leave both unset): collectors exit from the Hetzner datacenter
#       IP. Simplest, honest for "how does the open internet see X", but useless
#       for observing what a censored region sees, and easy for targets to flag.
#
#   (b) PROXY (set the vars below): route collectors through your residential /
#       in-region exit (e.g. the rockorbust layer). Required for the velocity
#       leg to see region-specific deletion. Costs egress + upkeep.
#
# Wire (b) by pointing these at your proxy. CENSORWATCH_PROXY_URL is the
# velocity-leg-specific override; HTTP(S)_PROXY covers the general collectors.
# =============================================================================
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=localhost,127.0.0.1,postgres,redis
# CENSORWATCH_PROXY_URL=

# --- feature flags -----------------------------------------------------------
# Master switch for the deletion-detection velocity leg. Leave UNSET to keep it
# inert (default). Set to 1 only alongside WITH_BROWSER=true and the velocity
# profile, and only once your proxy exit above is configured.
# CENSORWATCH_ENABLED=1
# WITH_BROWSER=true
